MAX_BOT_TOKEN=replace_with_real_bot_token
TZ=Europe/Moscow

POSTGRES_DB=maxbot
POSTGRES_USER=maxbot
POSTGRES_PASSWORD=maxbot
POSTGRES_PORT=5432

CORE_API_PORT=8091
BOT_PORT=8080

MAX_RUN_MODE=polling
MAX_API_BASE=https://platform-api.max.ru
MAX_POLL_TIMEOUT=30
MAX_POLL_LIMIT=100
MAX_POLL_MARKER_FILE=/var/bot_state/polling_marker
BOT_STATE_HOST_DIR=./var/bot_state

REFERENCE_API_TIMEOUT=5s
REFERENCE_CACHE_TTL=5m
CORE_API_TIMEOUT=5s
MEDIA_UPLOAD_ROOT=/var/www/violations-upload
MEDIA_UPLOAD_HOST_DIR=./var/uploads
REPORT_PIPELINE_ENABLED=true
REPORT_OUTBOX_DIR=var/report_outbox

LOG_FORMAT=text
LOG_LEVEL=info
