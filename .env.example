# Copy this file to .env and replace only the required secrets.

# Required
MAX_BOT_TOKEN=replace_with_real_max_bot_token

# MAX API
MAX_API_BASE=https://platform-api.max.ru
MAX_RUN_MODE=polling

# Polling
MAX_POLL_TIMEOUT=30
MAX_POLL_LIMIT=100
MAX_POLL_ONCE=0
MAX_POLL_MAX_CYCLES=0
MAX_LOG_EMPTY_POLLS=0

# Webhook (optional)
# MAX_WEBHOOK_ADDR=:8080
# MAX_WEBHOOK_PATH=/webhook/max
# MAX_WEBHOOK_SECRET=
# MAX_WEBHOOK_QUEUE_SIZE=512
# MAX_HTTP_READ_TIMEOUT=10s
# MAX_HTTP_WRITE_TIMEOUT=10s
# MAX_SHUTDOWN_TIMEOUT=10s

# Backend APIs
REFERENCE_API_BASE=http://127.0.0.1:8091
REFERENCE_API_TIMEOUT=5s
REFERENCE_CACHE_TTL=5m

CORE_API_BASE=http://127.0.0.1:8091
CORE_API_TIMEOUT=5s

# Raw dialog pipeline
REPORT_PIPELINE_ENABLED=true
REPORT_DATABASE_URL=postgres://maxbot:maxbot@127.0.0.1:5432/maxbot?sslmode=disable
REPORT_OUTBOX_DIR=var/report_outbox
REPORT_OUTBOX_QUEUE_SIZE=256
REPORT_OUTBOX_RETRY_BASE=1s
REPORT_OUTBOX_RETRY_MAX=30s

# Logging
LOG_FORMAT=text
LOG_LEVEL=info
